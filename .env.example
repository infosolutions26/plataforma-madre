# Base de datos. En desarrollo local no hace falta tocar esto (usa SQLite).
# En producción (Render) apunta a la cadena de conexión de Postgres administrado,
# ej: postgresql://usuario:password@host/nombre_db
DATABASE_URL=sqlite:///./plataforma_madre.db

# Llave de cifrado para SSN/ITIN completos (Fernet, 32 bytes en base64).
# Generarla una vez con: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# y NO perderla: si se pierde, los SSN cifrados ya guardados no se pueden recuperar.
SSN_ENCRYPTION_KEY=

# Credenciales de OAuth de Google Cloud Console (ver README para los pasos exactos).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Opcional. Si lo llenas (ej. solutionstaxes.com), solo se puede iniciar sesión
# con correos de ese dominio. Déjalo VACÍO si el equipo usa correos mixtos
# (algunos @tudominio.com, otros @gmail.com) — en ese caso el único control de
# acceso real es que el correo esté dado de alta como trabajador (ver abajo).
ALLOWED_GOOGLE_DOMAIN=

# Llave para firmar las cookies de sesión — cualquier cadena larga y aleatoria.
SESSION_SECRET_KEY=
